# Python 字节码与缓存
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# 虚拟环境
venv/
.venv/
env/
ENV/

# IDE 与编辑器配置
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
Desktop.ini

# 本地敏感配置
.env
.env.local
.env.*.local

# 日志文件
*.log
logs/

# 运行时缓存与临时文件
.cache/
temp/
tmp/

# 模型文件（大二进制，不纳入版本控制）
models/**/*.bin
models/**/*.onnx
models/**/*.pb
models/**/*.tflite
models/**/*.safetensors
models/**/*.ckpt
models/**/*.pth
models/**/*.pt
models/vosk/**
models/ivector/**

# 生成图片（每天产出，不应提交）
generated_images/
output_images/

# 数据集与训练数据
data/
datasets/

# 文档与报告（可选）
reports/
*.pdf
*.docx

# 编译产物（如果有 C++ 扩展）
*.so
*.dylib
*.dll
*.lib